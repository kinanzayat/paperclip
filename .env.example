DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false

# AgentMail MVP webhook intake
# Generate a secret with the PowerShell command below.
PAPERCLIP_AGENTMAIL_WEBHOOK_SECRET=replace-with-generated-secret

# AgentMail mailbox that receives meeting emails / Fireflies summaries.
PAPERCLIP_AGENTMAIL_INBOUND_MAILBOX=meetings@your-company.example

# Product analyzer email is now configured per company in Settings -> Company Settings.

# AgentMail API settings for outbound summary emails.
PAPERCLIP_AGENTMAIL_API_KEY=am_live_replace_this
PAPERCLIP_AGENTMAIL_API_BASE_URL=https://api.agentmail.to/v0
# Optional. If omitted, Paperclip will call /v0/inboxes and use the first inbox.
PAPERCLIP_AGENTMAIL_OUTBOUND_INBOX_ID=

# PowerShell example:
# $bytes = New-Object byte[] 32; [System.Security.Cryptography.RandomNumberGenerator]::Fill($bytes); [Convert]::ToHexString($bytes).ToLower()
